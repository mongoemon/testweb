# Copy this file and rename it to .env.<environment>
# Then set the values for that environment.

ENVIRONMENT=prod

# Absolute path or relative to backend/ directory
DATABASE_URL=./shop.db

# Use a long random string — never share or commit real keys
SECRET_KEY=replace-with-a-strong-random-secret-key

DEBUG=false

# true  = auto seed on startup (good for QA/dev, bad for staging/prod)
AUTO_SEED=false

# "*" allows all origins; for production set the actual URL
CORS_ORIGINS=https://yourapp.onrender.com
